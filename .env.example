# API keys
METOFFICE_API_KEY=
TFL_API_KEY=

# Cloudflare worker URL — set after deploy (synced to arduino/dashboard/config.h)
WORKER_URL=https://reterminal.<your-subdomain>.workers.dev/

# WiFi (synced to arduino/dashboard/config.h)
# Quote SSIDs with spaces or apostrophes, e.g. WIFI_SSID="Kim's Room"
# ESP32 is 2.4 GHz only — use the 2.4 GHz SSID, not a 5 GHz-only name.
WIFI_SSID=
WIFI_PASS=

# TfL (synced to cloudflare/.dev.vars and wrangler.jsonc)
TFL_LINE=elizabeth
TFL_LINE_NAME=Elizabeth line
TFL_STOP=910GEALINGB
TFL_STOP_NAME=Ealing Broadway
TFL_DIRECTION=inbound
TFL_DIRECTION_LABEL=Eastbound

# Met Office Global Spot (synced to cloudflare/.dev.vars and wrangler.jsonc)
WEATHER_LAT=51.5130
WEATHER_LON=-0.3089
WEATHER_LOCATION_NAME=Ealing, London

# Worker cache TTLs in seconds (synced to cloudflare/wrangler.jsonc; optional — omit to keep existing values)
# TFL_CACHE_SECONDS=5
# WEATHER_CACHE_SECONDS=900
